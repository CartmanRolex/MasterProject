# ── Python byte-compiled files ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── Isaac Sim streaming logs (NvStreamer output, auto-generated) ────────
isaac-inference/${data}/
*.etli

# ── Isaac Sim / LeRobot large datasets ─────────────────────────────────
isaac-inference/teleop-datasets/
isaac-inference/synthetic_datasets/

# ── Cluster training outputs ────────────────────────────────────────────
cluster-training/bash-out/
cluster-training/outputs/

# ── Debug snapshots ─────────────────────────────────────────────────────
isaac-inference/debug/
isaac-inference/explore_tests/
isaac-inference/results/**/snapshots/

# ── Inference run logs ───────────────────────────────────────────────────
isaac-inference/logs/
isaac-inference/logs.txt

# ── Local assistant/tool settings ────────────────────────────────────────
# Ignore everything under .claude/ EXCEPT the shared, version-controlled
# workflow config (subagents + notification hooks). settings.local.json (local
# permission approvals) and transient state stay ignored. Tracking agents/ and
# settings.json also makes them available inside git worktrees.
.claude/*
!.claude/agents/
!.claude/settings.json

# ── LaTeX build artifacts ────────────────────────────────────────────────
report/*.aux
report/*.bbl
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.synctex.gz
report/*.toc
report/*.pdf
